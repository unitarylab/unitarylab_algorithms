            "name": "t",
            "value": "1.0",
            "pattern": "^-?\\d+(\\.\\d+)?$",
            "description": "Hopping t",
            "info": "请输入实数，如 1.0"
        },
        {
            "help": "On-site interaction strength.",
            "name": "U",
            "value": "4.0",
            "pattern": "^-?\\d+(\\.\\d+)?$",
            "description": "Interaction U",
            "info": "请输入实数，如 4.0"
        },
        {
            "help": "Zeeman magnetic-field coefficient.",
            "name": "B",
            "value": "1.5",
            "pattern": "^-?\\d+(\\.\\d+)?$",
            "description": "Magnetic field B",
            "info": "请输入实数，如 1.5"
        },
        {
            "max": 10,
            "min": 1,
            "help": "Number of Ry-Rz ring-entangling ansatz layers.",

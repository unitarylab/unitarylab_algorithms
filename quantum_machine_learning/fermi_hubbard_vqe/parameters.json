            "value": "1000",
            "pattern": "^[1-9]\\d*$",
            "description": "Max optimizer iterations",
            "info": "请输入正整数，如 1000"
        },
        {
            "help": "Random seed for initial VQE parameters.",
            "name": "seed",
            "value": "7",
            "pattern": "^-?\\d+$",
            "description": "Random seed",
            "info": "请输入整数，如 7"
        },
        {
            "help": "Optional shots for total-spin magnetic-moment measurement. Use 0 to skip measurement.",
            "name": "measure_shots",
            "value": "10000",
            "pattern": "^\\d+$",
            "description": "Measurement shots",
            "info": "请输入非负整数；0 表示跳过测量"

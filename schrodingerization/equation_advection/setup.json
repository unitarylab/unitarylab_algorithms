{
    "params": [
        {
            "boundary_condition": [
                {
                    "latex": "$u(0, t) = u(L, t)$",
                    "name": "Periodic boundary",
                    "par_fix": [],
                    "par_func": [],
                    "type": "boundaryCondition_periodic"
                },
                {
                    "latex": "$u(0, t) = u_l, u(L, t) = u_r$",
                    "name": "Dirichlet boundary",
                    "par_fix": [
                        {
                            "description": "Left value",
                            "help": "ul specifies the left value of the Dirichlet boundary condition.",
                            "name": "ul",
                            "value": "0",
                            "pattern": "^[+-]?(0|[1-9]\\d*)(\\.\\d+)?([eE][+-]?\\d+)?$"
                        },
                        {
                            "description": "Right value",
                            "help": "ur specifies the right value of the Dirichlet boundary condition.",
                            "name": "ur",
                            "value": "1",
                            "pattern": "^[+-]?(0|[1-9]\\d*)(\\.\\d+)?([eE][+-]?\\d+)?$"
                        }
                    ],
                    "par_func": [],
                    "type": "boundaryCondition_dirichlet"
                }
            ],
            "discrete_format": [
                {
                    "latex": "$\\Delta u_{i} \\approx \\frac{\\Delta t}{\\Delta x} (u_{i}^{n} - u_{i-1}^{n}), a > 0$",
                    "name": "Upwind scheme",
                    "par_fix": [
                        {
                            "description": "Number of spatial qubits",
                            "help": "nx (which can take multiple values) specifies the number of spatial qubits, controlling the precision of the spatial discretization.",
                            "name": "nx",
                            "value": "4",
                            "min": 1,
                            "max": 10,
                            "pattern": "^[1-9]\\d*$"
                        }
                    ],
                    "par_func": [],
                    "type": "discreteFormat_upwind"
                },
                {
                    "latex": "$\\Delta u_{i} \\approx a \\frac{\\Delta t}{2\\Delta x} (u_{i+1}^{n} - u_{i-1}^{n})$",
                    "name": "Central difference scheme",
                    "par_fix": [
                        {
                            "description": "Number of spatial qubits",
                            "help": "nx (which can take multiple values) specifies the number of spatial qubits, controlling the precision of the spatial discretization.",
                            "name": "nx",
                            "value": "4",
                            "min": 1,
                            "max": 10,
                            "pattern": "^[1-9]\\d*$"
                        }
                    ],
                    "par_func": [],
                    "type": "discreteFormat_central"
                }
            ],
            "equation": {
                "boundary_condition": "boundaryCondition_periodic",
                "discrete_format": "discreteFormat_upwind",
                "hamiltonian": "hamiltonian_original",
                "initial_condition": "initialCondition_discontinuous",
                "method_list": [
                    "solutionMethod_classical",
                    "solutionMethod_trotter"
                ],
                "group_index": "advection",
                "latex": "$\\frac{\\partial u}{\\partial t} = a \\frac{\\partial u}{\\partial x}$",
                "name": "1D Advection equation",
                "par_fix": [
                    {
                        "description": "Velocity",
                        "help": "a is the velocity of the advection equation, which determines the speed of wave propagation. The upwind scheme is related to the sign of a.",
                        "name": "a",
                        "value": "0.1",
                        "min": -100,
                        "max": 100,
                        "pattern": "^[+-]?(0|[1-9]\\d*)(\\.\\d+)?([eE][+-]?\\d+)?$"
                    },
                    {
                        "description": "Computational domain length",
                        "help": "L is the length of the computational domain, and the default computational domain is [0, L].",
                        "name": "L",
                        "value": "16",
                        "min": 0,
                        "max": 100,
                        "exclusiveMin": true,
                        "pattern": "^[+]?(0|[1-9]\\d*)(\\.\\d+)?([eE][+-]?\\d+)?$"
                    },
                    {
                        "description": "Final time",
                        "help": "T is the final time of the simulation. The default calculation time is [0, T].",
                        "name": "T",
                        "value": "1",
                        "min": 0,
                        "max": 100,
                        "exclusiveMin": true,
                        "pattern": "^[+]?(0|[1-9]\\d*)(\\.\\d+)?([eE][+-]?\\d+)?$"
                    }
                ],
                "par_func": [],
                "type": "equation_advection"
            },
            "hamiltonian": [
                {
                    "description": "Preprocessing",
                    "help": "Some equations need to be transformed into a better formulation. For details, see the documentation",
                    "latex": "$H = \\hat{\\eta} \\otimes H_1 + I \\otimes H_2, \\quad H_1 = 0, \\quad H_2 = a\\hat{p} $",
                    "name": "No pre-processing is required",
                    "type": "hamiltonian_original",
                    "derivative": [
                        {
                            "parameter_indicator": "x",
                            "parameter_coefficient": "a"
                        }
                    ]
                }
            ],
            "initial_condition": [
                {
                    "latex": "$u(x, 0) = 0, \\ x\\in [0, L/2), \\quad u(x, 0) = 1, \\ x\\in [L/2, L]$",
                    "name": "Discontinuous function",
                    "par_fix": [],
                    "par_func": [],
                    "type": "initialCondition_discontinuous"
                },
                {
                    "latex": "$u(x, 0) = u_0(x)$",
                    "name": "Customized initial function",
                    "par_fix": [],
                    "par_func": [
                        {
                            "description": "Customized initial function",
                            "help": "u0(x) is the initial function. ",
                            "latex": "$u_0(x) = \\sin(2\\pi x/L)$",
                            "name": "u0(x)",
                            "value": "sin(2*pi*x/L)",
                            "par": []
                        }
                    ],
                    "type": "initialCondition_custom"
                }
            ],
            "type": "advection"
        },
        {
            "help": "The hamiltonian evolution is classically implemented, i.e., use scipy.expm to compute the matrix exponential.",
            "latex": "$\\frac{\\partial u}{\\partial t} = -i (\\eta H_1 + H_2) u$",
            "name": "Classical implementation",
            "par_fix": [
                {
                    "description": "Number of ancilla qubits",
                    "help": "na (which can take multiple values) specifies the number of ancilla qubits, governing the discretization accuracy of the parameter p in the Schrödingerization method.",
                    "name": "na",
                    "value": "8",
                    "min": 1,
                    "max": 10,
                    "pattern": "^[1-9]\\d*$"
                },
                {
                    "description": "Length of p region",
                    "help": "p is truncated in [-pi*R, pi*R], which is the domain of the parameter p in the Schrödingerization method.",
                    "name": "R",
                    "value": "4",
                    "min": 0,
                    "max": 100,
                    "exclusiveMin": true,
                    "pattern": "^[+]?(0|[1-9]\\d*)(\\.\\d+)?([eE][+-]?\\d+)?$"
                },
                {
                    "description": "Recover point",
                    "help": "After the Schrödingerization method, the solution is recovered at the point p. If p is not specified, the default value is 1.",
                    "name": "p",
                    "value": "1",
                    "pattern": "^[+-]?(0|[1-9]\\d*)(\\.\\d+)?([eE][+-]?\\d+)?$"
                }
            ],
            "par_func": [],
            "type": "solutionMethod_classical"
        }
    ]
}